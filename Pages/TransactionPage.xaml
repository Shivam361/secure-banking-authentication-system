<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.TransactionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Funds Transfer"
    BackgroundColor="{StaticResource OffBlack}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="30" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8">
                <Label Text="Global Transfer" Style="{StaticResource Headline}" HorizontalOptions="Start" />
                <Label Text="Secure, instantaneous settlement." Style="{StaticResource SubHeadline}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="RECIPIENT" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="ToUserEntry" Placeholder="Username" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="AMOUNT (USD)" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="AmountEntry" Placeholder="0.00" Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="REFERENCE (OPTIONAL)" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="ReferenceEntry" Placeholder="e.g. Dinner refund" Keyboard="Text" />
                    </VerticalStackLayout>

                    <Button x:Name="SubmitButton"
                            Text="CONFIRM SETTLEMENT"
                            Style="{StaticResource AccentButton}"
                            Clicked="OnSubmitClicked"
                            IsEnabled="{Binding IsNotBusy}" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource AccentGold}"
                                       HorizontalOptions="Center" />

                    <Label x:Name="TxErrorLabel"
                           TextColor="{StaticResource StatusError}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <Label x:Name="TxSuccessLabel"
                           TextColor="{StaticResource StatusSuccess}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
