<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.RegistrationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Premium Enrollment"
    BackgroundColor="{StaticResource OffBlack}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="30" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8">
                <Label Text="Create Your Account" Style="{StaticResource Headline}" HorizontalOptions="Start" />
                <Label Text="Join our secure global banking network." Style="{StaticResource SubHeadline}" HorizontalOptions="Start" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="IDENTIFIER" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="UsernameEntry" Placeholder="Username" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="EMAIL ADDRESS" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="EmailEntry" Placeholder="email@example.com" Keyboard="Email" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="SECRET KEY" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="PasswordEntry" Placeholder="••••••••" IsPassword="True" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="CONFIRM KEY" TextColor="{StaticResource Gray400}" FontSize="10" CharacterSpacing="1" Margin="4,0"/>
                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="••••••••" IsPassword="True" />
                    </VerticalStackLayout>

                    <Button x:Name="RegisterButton"
                            Text="PROCEED TO ENROLLMENT"
                            Style="{StaticResource AccentButton}"
                            Clicked="OnRegisterClicked" />

                    <Label x:Name="RegErrorLabel" 
                           TextColor="{StaticResource StatusError}" 
                           FontSize="13" 
                           HorizontalTextAlignment="Center" />
                    
                    <Label x:Name="RegSuccessLabel" 
                           TextColor="{StaticResource StatusSuccess}" 
                           FontSize="13" 
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Frame>

            <Button Text="Already have an account? Login" 
                    Style="{StaticResource GlassButton}"
                    Clicked="OnRegisterClicked" 
                    HorizontalOptions="Center"
                    FontSize="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
