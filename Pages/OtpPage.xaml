<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.OtpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Security Verification"
    BackgroundColor="{StaticResource OffBlack}">

    <ContentPage.Content>
        <VerticalStackLayout Padding="40" Spacing="40" VerticalOptions="Center">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="Verify Your Identity" Style="{StaticResource Headline}" FontSize="24" />
                <Label Text="A 6-digit code has been sent to your email." 
                       Style="{StaticResource SubHeadline}" 
                       FontSize="13" 
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource GlassCard}" WidthRequest="320">
                <VerticalStackLayout Spacing="24">
                    
                    <!-- Code Input Area -->
                    <Grid HeightRequest="70">
                        <Frame x:Name="OtpFrame"
                               Style="{StaticResource PremiumCard}"
                               BackgroundColor="{StaticResource Gray800}"
                               Padding="0"
                               HasShadow="False">
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BorderColor" Value="{StaticResource GlassBorder}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Error">
                                        <VisualState.Setters>
                                            <Setter Property="BorderColor" Value="{StaticResource StatusError}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Entry x:Name="OtpEntry"
                                   Placeholder="000000"
                                   Keyboard="Numeric"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource AccentGold}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   MaxLength="6" />
                        </Frame>

                        <BoxView x:Name="Shimmer"
                                 CornerRadius="20"
                                 BackgroundColor="{StaticResource White}"
                                 Opacity="0.1"
                                 IsVisible="False" />
                    </Grid>

                    <Button x:Name="VerifyButton"
                            Text="{Binding VerifyButtonText}"
                            Style="{StaticResource AccentButton}"
                            Clicked="OnVerifyClicked"
                            IsEnabled="{Binding IsNotBusy}" />

                    <Button x:Name="ResendButton"
                            Text="RESEND SECURITY CODE"
                            Style="{StaticResource GlassButton}"
                            Clicked="OnResendClicked"
                            IsEnabled="{Binding CanResend}" />

                    <Label x:Name="ResendCooldownLabel"
                           FontSize="12"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="20">
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource AccentGold}"
                                   HorizontalOptions="Center" />

                <Label x:Name="OtpErrorLabel"
                       FontSize="14"
                       TextColor="{StaticResource StatusError}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>
