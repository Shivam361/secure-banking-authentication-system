<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Institutional Dashboard"
    BackgroundColor="{StaticResource OffBlack}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Header Section -->
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Welcome back," 
                           TextColor="{StaticResource Gray400}" 
                           FontSize="14" />
                    <Label Text="Secure Account" 
                           FontSize="24" 
                           FontAttributes="Bold" />
                </VerticalStackLayout>
                
                <!-- Notification / User Icon placeholder -->
                <Frame Grid.Column="1" 
                       WidthRequest="50" 
                       HeightRequest="50" 
                       CornerRadius="25" 
                       Padding="0" 
                       BackgroundColor="{StaticResource Gray800}" 
                       BorderColor="{StaticResource GlassBorder}">
                    <Label Text="JS" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           TextColor="{StaticResource AccentGold}" 
                           FontAttributes="Bold" />
                </Frame>
            </Grid>

            <!-- Wealth Card -->
            <Frame Style="{StaticResource PremiumCard}" 
                   Padding="0" 
                   HasShadow="True">
                <Grid RowDefinitions="Auto, Auto" Padding="24">
                    <VerticalStackLayout Grid.Row="0" Spacing="8">
                        <Label Text="TOTAL BALANCE" 
                               TextColor="{StaticResource Gray400}" 
                               FontSize="12" 
                               CharacterSpacing="1" />
                        <Label x:Name="BalanceLabel" 
                               FontSize="36" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource White}" />
                    </VerticalStackLayout>
                    
                    <BoxView Grid.Row="1" 
                             HeightRequest="1" 
                             BackgroundColor="{StaticResource GlassBorder}" 
                             Margin="0,16" />
                    
                    <HorizontalStackLayout Grid.Row="1" 
                                           Spacing="12" 
                                           Margin="0,24,0,0">
                        <Label Text="Active Users:" TextColor="{StaticResource Gray400}"/>
                        <Label x:Name="UsersCountLabel" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource AccentCyan}" />
                    </HorizontalStackLayout>
                </Grid>
            </Frame>

            <!-- Action Grid -->
            <Grid ColumnDefinitions="*, *" 
                  RowDefinitions="Auto, Auto" 
                  ColumnSpacing="16" 
                  RowSpacing="16">
                
                <Button Grid.Row="0" Grid.Column="0"
                        Text="New Transfer" 
                        Style="{StaticResource AccentButton}"
                        Clicked="OnNewTransactionClicked" />

                <Button Grid.Row="0" Grid.Column="1"
                        Text="History" 
                        Style="{StaticResource GlassButton}"
                        Clicked="OnViewTransactionsClicked" />

                <!-- Security alerts - integrated badge -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2">
                    <Button x:Name="FraudLogButton" 
                            Text="Security Alerts" 
                            Style="{StaticResource GlassButton}"
                            Clicked="OnFraudLogClicked"
                            TextColor="{StaticResource StatusError}"
                            BorderColor="{StaticResource StatusError}" />
                    
                    <Frame x:Name="FraudBadgeFrame"
                           IsVisible="False"
                           BackgroundColor="{StaticResource StatusError}"
                           CornerRadius="10"
                           Padding="6,2"
                           HeightRequest="20"
                           WidthRequest="30"
                           HorizontalOptions="End"
                           VerticalOptions="Start"
                           Margin="0,-8,-8,0"
                           HasShadow="False">
                        <Label x:Name="FraudBadge" 
                               FontSize="10" 
                               TextColor="{StaticResource White}" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                    </Frame>
                </Grid>
            </Grid>

            <!-- Admin Section -->
            <VerticalStackLayout x:Name="AdminPanel" Spacing="12">
                <Label Text="ADMINISTRATION" 
                       TextColor="{StaticResource Gray500}" 
                       FontSize="11" 
                       FontAttributes="Bold" 
                       CharacterSpacing="2" />
                
                <Button x:Name="AdminUserButton" 
                        Text="Manage Users" 
                        IsVisible="False" 
                        Clicked="OnAdminUserClicked" 
                        Style="{StaticResource GlassButton}" />
                
                <Button x:Name="AdminTxButton" 
                        Text="Audit Transactions" 
                        IsVisible="False" 
                        Clicked="OnAdminTxClicked" 
                        Style="{StaticResource GlassButton}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
