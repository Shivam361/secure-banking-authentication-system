<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Welcome to your secure dashboard!" FontSize="18" />
        <Label Text="Total users:" />
        <Label x:Name="UsersCountLabel" FontAttributes="Bold" FontSize="24" />
        <!-- inside your MainPage layout, e.g. below users count -->
        <Button
    Text="New Transaction"
    Clicked="OnNewTransactionClicked"
    CornerRadius="5"
    BackgroundColor="#512BD4"
    TextColor="White" />
        <Button
    Text="View Transaction History"
    Clicked="OnViewTransactionsClicked"
    CornerRadius="5"
    BackgroundColor="#512BD4"
    TextColor="White"
    Margin="0,8" />
        <Label x:Name="BalanceLabel"
       FontSize="22"
       TextColor="#1D6D24"
       FontAttributes="Bold"
       Margin="0,0,0,20"/>
        <Button
    x:Name="FraudLogButton"
    Text="Fraud Alerts"
    Clicked="OnFraudLogClicked"
    FontSize="18"
    BackgroundColor="#D43B3B"
    TextColor="White"
    Margin="0,10,0,0"/>
        <Label x:Name="FraudBadge"
       FontSize="14"
       TextColor="White"
       BackgroundColor="#E74C3C"
       IsVisible="False"
       HorizontalOptions="End"
       VerticalOptions="Start"
       Padding="6,1"
       Margin="0,-35,15,0"/>
        <Button
    x:Name="AdminUserButton"
    Text="View All Users"
    IsVisible="False"
    Clicked="OnAdminUserClicked"
    BackgroundColor="#0D47A1"
    TextColor="White"
    Margin="0,10,0,0"/>
        <Button
    x:Name="AdminTxButton"
    Text="View All Transactions"
    IsVisible="False"
    Clicked="OnAdminTxClicked"
    BackgroundColor="#0097A7"
    TextColor="White"
    Margin="0,10,0,20"/>



    </VerticalStackLayout>
</ContentPage>
