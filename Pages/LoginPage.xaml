<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Secure Banking"
    BackgroundColor="Transparent">

    <!-- Premium Background Gradient -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#020617" Offset="0.1" />
            <GradientStop Color="#0F172A" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout
            Padding="40"
            Spacing="40"
            VerticalOptions="Center">

            <!-- Premium App Branding -->
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Frame CornerRadius="20" 
                       HeightRequest="80" 
                       WidthRequest="80" 
                       Padding="0"
                       BackgroundColor="{DynamicResource GlassBackground}"
                       BorderColor="{DynamicResource GlassBorder}">
                    <Label Text="S" 
                           FontSize="40" 
                           FontAttributes="Bold" 
                           TextColor="{DynamicResource AccentGold}"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" />
                </Frame>
                <Label Text="SECURE BANK" 
                       Style="{DynamicResource Headline}" 
                       FontSize="24"/>
                <Label Text="Institutional Grade Security" 
                       Style="{DynamicResource SubHeadline}" 
                       FontSize="14"/>
            </VerticalStackLayout>

            <!-- Login Card -->
            <Frame Style="{DynamicResource GlassCard}" 
                   WidthRequest="350">
                
                <VerticalStackLayout Spacing="24">
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Username" TextColor="{DynamicResource Gray300}" FontSize="12" Margin="4,0"/>
                        <Entry x:Name="UsernameEntry" 
                               Placeholder="Enter your username" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Password" TextColor="{DynamicResource Gray300}" FontSize="12" Margin="4,0"/>
                        <Entry x:Name="PasswordEntry" 
                               Placeholder="••••••••" 
                               IsPassword="True" />
                    </VerticalStackLayout>

                    <Button x:Name="LoginButton" 
                            Text="{Binding LoginButtonText}" 
                            Style="{DynamicResource AccentButton}"
                            Clicked="OnLoginClicked"
                            IsEnabled="{Binding IsNotBusy}" />

                    <Button x:Name="BiometricButton" 
                            Text="Biometric Login" 
                            Style="{DynamicResource GlassButton}"
                            Clicked="OnBiometricClicked"
                            IsVisible="False" />

                    <Button Text="Create New Account" 
                            Style="{DynamicResource GlassButton}"
                            Clicked="OnRegisterButtonClicked" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}" 
                                       IsRunning="{Binding IsBusy}" 
                                       Color="{DynamicResource AccentGold}"
                                       HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Frame>

            <!-- Error Message -->
            <Label x:Name="ErrorLabel" 
                   TextColor="{DynamicResource StatusError}" 
                   FontSize="14" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
