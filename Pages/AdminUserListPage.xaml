<ContentPage
    x:Class="SecureBankingApp.Pages.AdminUserListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="All Users"
    BackgroundColor="Black">
    <VerticalStackLayout Padding="16" Spacing="10">
        <Label Text="All Users" FontSize="26" FontAttributes="Bold" />
        <CollectionView x:Name="UserList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="8" HasShadow="True" BackgroundColor="DarkGray">
                        <VerticalStackLayout>
                            <Label Text="{Binding Username}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Email}" FontSize="15" />
                            <Label Text="{Binding Balance, StringFormat='Balance: {0:C}'}" FontSize="14" />
                            <Label Text="{Binding LastLoginIP, StringFormat='Last IP: {0}'}" FontSize="12" TextColor="White"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
