<ContentPage
    x:Class="SecureBankingApp.Pages.AdminTransactionListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="All Transactions"
    BackgroundColor="Black">
    <VerticalStackLayout Padding="16" Spacing="10">
        <Label Text="All Transactions" FontSize="26" FontAttributes="Bold" />
        <CollectionView x:Name="TxList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="8" HasShadow="True" BackgroundColor="DarkGray">
                        <VerticalStackLayout>
                            <Label Text="{Binding FromUsername}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding ToUsername, StringFormat='→ {0}'}" FontSize="16" />
                            <Label Text="{Binding Amount, StringFormat='Amount: {0:C}'}" FontSize="14" />
                            <Label Text="{Binding Location, StringFormat='Location: {0}'}" FontSize="12" />
                            <Label Text="{Binding Timestamp, StringFormat='Date: {0:dd MMM yyyy HH:mm}'}" FontSize="12" TextColor="White"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
