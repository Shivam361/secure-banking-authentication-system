<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.AdminTransactionListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Transaction Audit"
    BackgroundColor="{StaticResource OffBlack}">

    <VerticalStackLayout Padding="24" Spacing="20">
        <Label Text="System-Wide Ledger" Style="{StaticResource Headline}" HorizontalOptions="Start" FontSize="22" />

        <CollectionView x:Name="TxList">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource GlassCard}" Padding="16">
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                            
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding FromUsername}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="{StaticResource White}" />
                                    <Label Text="→" 
                                           FontSize="16" 
                                           TextColor="{StaticResource AccentGold}" />
                                    <Label Text="{Binding ToUsername}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="{StaticResource White}" />
                                </HorizontalStackLayout>
                                
                                <Label Text="{Binding Timestamp, StringFormat='Settled: {0:dd MMM yyyy • HH:mm:ss}'}" 
                                       FontSize="11" 
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1" 
                                   Text="{Binding Amount, StringFormat='{0:C}'}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="{StaticResource AccentGold}" 
                                   VerticalOptions="Center" />
                            
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2" 
                                     HeightRequest="1" 
                                     BackgroundColor="{StaticResource GlassBorder}" 
                                     Margin="0,8,0,0" />
                            
                            <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" 
                                                   Spacing="10" 
                                                   Margin="0,12,0,0">
                                <Label Text="ORIGIN:" 
                                       FontSize="10" 
                                       FontAttributes="Bold" 
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Location}" 
                                       FontSize="10" 
                                       TextColor="{StaticResource Gray400}" 
                                       FontAttributes="Italic" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="100" HorizontalOptions="Center" Spacing="10">
                    <Label Text="The ledger is currently clear." 
                           TextColor="{StaticResource Gray600}" 
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
