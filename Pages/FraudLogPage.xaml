<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecureBankingApp.Pages.FraudLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Security Audit"
    BackgroundColor="{StaticResource OffBlack}">

    <VerticalStackLayout Padding="24" Spacing="20">
        <Label Text="Threat Intelligence Log" Style="{StaticResource Headline}" HorizontalOptions="Start" FontSize="22" />

        <CollectionView x:Name="FraudList">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource GlassCard}" 
                           BorderColor="{StaticResource StatusError}" 
                           Padding="16" 
                           BackgroundColor="#1AEE4444">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Description}" 
                                   Style="{StaticResource SubHeadline}" 
                                   HorizontalOptions="Start" 
                                   TextColor="{StaticResource StatusError}" 
                                   FontSize="14" />
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="DETECTED:" 
                                       FontSize="10" 
                                       FontAttributes="Bold" 
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Timestamp, StringFormat='{0:dd MMM yyyy • HH:mm:ss}'}" 
                                       FontSize="10" 
                                       TextColor="{StaticResource Gray400}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="100" HorizontalOptions="Center" Spacing="10">
                    <Label Text="No active threats detected." 
                           TextColor="{StaticResource StatusSuccess}" 
                           FontAttributes="Bold" 
                           HorizontalTextAlignment="Center" />
                    <Label Text="System status: Nominal" 
                           TextColor="{StaticResource Gray600}" 
                           FontSize="12" 
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
