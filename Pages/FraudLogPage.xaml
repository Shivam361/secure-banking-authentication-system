<ContentPage
    x:Class="SecureBankingApp.Pages.FraudLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Fraud Log"
    BackgroundColor="White">
    <VerticalStackLayout Padding="16" Spacing="10">
        <Label Text="Fraud Log" FontSize="26" FontAttributes="Bold" />
        <CollectionView x:Name="FraudList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="8" HasShadow="True" BackgroundColor="#FFF0F0">
                        <VerticalStackLayout>
                            <Label Text="{Binding Description}" FontSize="16" TextColor="#E74C3C"/>
                            <Label Text="{Binding Timestamp, StringFormat='{0:dd MMM yyyy HH:mm}'}" FontSize="12" TextColor="#888"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
