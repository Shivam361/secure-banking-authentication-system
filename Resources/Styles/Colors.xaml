<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Midnight Sapphire Palette -->
    <Color x:Key="Primary">#0F172A</Color>
    <Color x:Key="PrimaryLight">#1E293B</Color>
    <Color x:Key="Secondary">#10B981</Color>
    <Color x:Key="Tertiary">#334155</Color>

    <!-- Accent & Highlights -->
    <Color x:Key="AccentGold">#F59E0B</Color>
    <Color x:Key="AccentCyan">#06B6D4</Color>
    <Color x:Key="StatusError">#EF4444</Color>
    <Color x:Key="StatusSuccess">#10B981</Color>

    <!-- Neutral Colors -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="OffWhite">#F8FAFC</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#020617</Color>

    <!-- Grays -->
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray700">#334155</Color>
    <Color x:Key="Gray800">#1E293B</Color>
    <Color x:Key="Gray900">#0F172A</Color>

    <!-- Glassmorphism Elements -->
    <Color x:Key="GlassBackground">#1AFFFFFF</Color>
    <Color x:Key="GlassBorder">#33FFFFFF</Color>
    <Color x:Key="GlassNavy">#CC0F172A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGold}"/>
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassBackground}"/>
    
    <LinearGradientBrush x:Key="PremiumGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F172A" Offset="0.1" />
        <GradientStop Color="#1E293B" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F59E0B" Offset="0.0" />
        <GradientStop Color="#D97706" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>